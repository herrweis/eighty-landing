# Google Sheets API Configuration
# See EMAIL_SETUP.md for detailed setup instructions

# Your Google Sheets spreadsheet ID (from the URL)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Service account email (from the JSON key file)
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com

# Service account private key (from the JSON key file)
# Include the full key with -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
